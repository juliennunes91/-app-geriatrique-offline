{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_STREAM_IDLE_TIMEOUT_MS": "600000"
  },
  "permissions": {
    "allow": [
      "Bash(pdftotext:*)",
      "Bash(pdfinfo:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git ls-tree:*)",
      "Bash(git ls-files:*)",
      "Bash(git fetch origin:*)",
      "Bash(grep -c:*)",
      "Bash(mkdir -p:*)",
      "WebFetch(domain:eutils.ncbi.nlm.nih.gov)",
      "WebFetch(domain:www.ncbi.nlm.nih.gov)",
      "WebFetch(domain:pubmed.ncbi.nlm.nih.gov)",
      "WebFetch(domain:api.openalex.org)",
      "WebFetch(domain:api.crossref.org)",
      "WebFetch(domain:api.semanticscholar.org)"
    ]
  },
  "sandbox": {
    "network": {
      "allowedDomains": [
        "eutils.ncbi.nlm.nih.gov",
        "www.ncbi.nlm.nih.gov",
        "pubmed.ncbi.nlm.nih.gov",
        "api.openalex.org",
        "api.crossref.org",
        "api.semanticscholar.org",
        "core.ac.uk",
        "api.unpaywall.org"
      ]
    }
  }
}
